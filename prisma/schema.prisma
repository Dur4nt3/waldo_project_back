generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  playerId Int    @id @default(autoincrement())
  name     String
  score    Int?
  completedLevels Int?

  gameSession GameSession?
}

model GameSession {
  gameSessionId Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  sessionToken  String   @unique
  levelCount    Int

  playerId Int    @unique
  player   Player @relation(fields: [playerId], references: [playerId], onDelete: Cascade)

  breakpointId Int
  breakpoint   Breakpoint @relation(fields: [breakpointId], references: [breakpointId])

  playerProgress GameProgress[]
}

model Image {
  imageId     Int    @id @default(autoincrement())
  name        String @unique
  description String

  level Level?

  characters Character[]
}

model Character {
  characterId Int    @id @default(autoincrement())
  name        String
  description String

  imageId Int
  image   Image @relation(fields: [imageId], references: [imageId], onDelete: Cascade)

  locations CharacterLocation[]

  @@unique([name, imageId], name: "unique_character_name_per_image")
}

model CharacterLocation {
  characterLocationId Int @id @default(autoincrement())

  characterId Int
  character   Character @relation(fields: [characterId], references: [characterId], onDelete: Cascade)

  breakpointId Int
  breakpoint   Breakpoint @relation(fields: [breakpointId], references: [breakpointId], onDelete: Cascade)

  xMin Float
  xMax Float

  yMin Float
  yMax Float

  @@unique([characterId, breakpointId], name: "unique_individual_character_location_per_breakpoint")
}

model Level {
  levelId    Int  @id @default(autoincrement())
  orderIndex Int? @unique

  imageId Int   @unique
  image   Image @relation(fields: [imageId], references: [imageId], onDelete: Cascade)

  playedBy GameProgress[]

  markers Marker[]
}

model Breakpoint {
  breakpointId   Int @id @default(autoincrement())
  minimumWidthPx Int @unique
  maximumWidthPx Int @unique

  sessions GameSession[]

  marker Marker[]

  locations CharacterLocation[]
}

model Marker {
  markerId Int @id @default(autoincrement())
  height   Int
  width    Int

  breakpointId Int
  breakpoint   Breakpoint @relation(fields: [breakpointId], references: [breakpointId], onDelete: Cascade)

  levelId Int
  level   Level @relation(fields: [levelId], references: [levelId])

  @@unique([levelId, breakpointId], name: "unique_marker_per_level_and_breakpoint")
}

model GameProgress {
  gameProgressId Int @id @default(autoincrement())

  levelId Int
  level   Level @relation(fields: [levelId], references: [levelId])

  gameSessionId Int
  sessionOwner  GameSession @relation(fields: [gameSessionId], references: [gameSessionId], onDelete: Cascade)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@unique([gameSessionId, levelId], name: "unique_individual_level_progress_per_session")
}
