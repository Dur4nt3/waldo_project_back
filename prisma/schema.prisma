generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  playerId Int    @id @default(autoincrement())
  name     String @unique
  score    Int

  gameSession GameSession?
}

model GameSession {
  gameSessionId Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  sessionToken  String
  levelCount    Int

  playerId Int    @unique
  player   Player @relation(fields: [playerId], references: [playerId])

  breakpointId Int
  breakpoint Breakpoint @relation(fields: [breakpointId], references: [breakpointId])

  playerProgress GameProgress[]
}

model Image {
  imageId     Int    @id @default(autoincrement())
  description String

  level Level?

  characters Character[]
}

model Character {
  characterId Int    @id @default(autoincrement())
  description String

  imageId Int
  image   Image @relation(fields: [imageId], references: [imageId])

  locations CharacterLocation[]
}

model CharacterLocation {
  characterLocationId Int @id @default(autoincrement())
  
  characterId Int
  character Character @relation(fields: [characterId], references: [characterId])

  breakpointId Int
  breakpoint Breakpoint @relation(fields: [breakpointId], references: [breakpointId])

  xMin Float
  xMax Float

  yMin Float
  yMax Float
}

model Level {
  levelId    Int @id @default(autoincrement())
  orderIndex Int @unique

  imageId Int   @unique
  image   Image @relation(fields: [imageId], references: [imageId])

  playedBy GameProgress[]
}

model Breakpoint {
  breakpointId   Int @id @default(autoincrement())
  minimumWidthPx Int @unique
  maximumWidthPx Int @unique

  sessions GameSession[]

  marker Marker?

  locations CharacterLocation[]
}

model Marker {
  markerId Int @id @default(autoincrement())
  height Int
  width Int

  breakpointId Int @unique
  breakpoint Breakpoint @relation(fields: [breakpointId], references: [breakpointId])
}

model GameProgress {
  gameProgressId Int @id @default(autoincrement())

  levelId Int
  level   Level @relation(fields: [levelId], references: [levelId])

  gameSessionId Int
  sessionOwner  GameSession @relation(fields: [gameSessionId], references: [gameSessionId])

  startedAt  DateTime @default(now())
  finishedAt DateTime
}
